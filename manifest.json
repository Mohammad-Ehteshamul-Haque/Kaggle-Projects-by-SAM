{
  "name": "Workaholics",
  "version": "0.1.0",
  "description": "Using typewriting performance and HRV from an external fitness tracker to predict fatigue levels",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "idle"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/bookmark.png",
        "assets/play.png",
        "assets/delete.png",
        "assets/save.png"
      ],
      "matches": [
        "https://docs.google.com/*",
        "https://mail.google.com/*"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/ext-icon.png",
      "24": "assets/ext-icon.png",
      "32": "assets/ext-icon.png"
    },
    "default_title": "Work work work",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}